{
  "name": "electrical-testing-suite",
  "productName": "Electrical Testing Suite",
  "version": "1.0.0",
  "description": "Insulation & LCR Multimeter Desktop Testing Application",
  "main": ".webpack/main",
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "build": "electron-forge make"
  },
  "keywords": [],
  "author": "Your Name",
  "license": "MIT",
  "dependencies": {
    "@vercel/webpack-asset-relocator-loader": "^1.10.0",
    "exceljs": "^4.4.0",
    "pdfkit": "^0.15.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^7.15.1",
    "recharts": "^2.15.4",
    "serialport": "^12.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "@babel/preset-react": "^7.23.3",
    "@electron-forge/cli": "^7.3.0",
    "@electron-forge/maker-squirrel": "^7.3.0",
    "@electron-forge/maker-zip": "^7.3.0",
    "@electron-forge/plugin-auto-unpack-natives": "^7.3.0",
    "@electron-forge/plugin-webpack": "^7.3.0",
    "@electron/rebuild": "^3.7.2",
    "autoprefixer": "^10.5.0",
    "babel-loader": "^9.1.3",
    "css-loader": "^6.10.0",
    "electron": "^29.1.0",
    "node-loader": "^2.0.0",
    "postcss": "^8.5.15",
    "style-loader": "^3.3.4",
    "tailwindcss": "^4.3.0"
  },
  "config": {
    "forge": {
      "packagerConfig": {
        "asar": true,
        "name": "ElectricalTestingSuite",
        "executableName": "ElectricalTestingSuite",
        "icon": "src/assets/icon"
      },
      "rebuildConfig": {},
      "makers": [
        {
          "name": "@electron-forge/maker-squirrel",
          "config": {
            "name": "ElectricalTestingSuite"
          }
        },
        {
          "name": "@electron-forge/maker-zip",
          "platforms": [
            "darwin",
            "linux"
          ]
        }
      ],
      "plugins": [
        {
          "name": "@electron-forge/plugin-auto-unpack-natives",
          "config": {}
        },
        {
          "name": "@electron-forge/plugin-webpack",
          "config": {
            "mainConfig": "./webpack.main.config.js",
            "renderer": {
              "config": "./webpack.renderer.config.js",
              "entryPoints": [
                {
                  "html": "./src/renderer/index.html",
                  "js": "./src/renderer/index.jsx",
                  "name": "main_window",
                  "preload": {
                    "js": "./src/main/preload.js"
                  }
                }
              ]
            }
          }
        }
      ]
    }
  }
}
